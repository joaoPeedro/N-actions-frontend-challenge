{
  "name": "marketplace-workspace",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "yarn workspace @marketplace/app dev",
    "build": "yarn workspace @marketplace/app build",
    "typecheck": "yarn workspace @marketplace/app typecheck",
    "clean": "rm -rf node_modules && yarn workspaces foreach -A exec rm -rf node_modules dist build .cache",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "yarn workspace @ds/design-system storybook",
    "test": "vitest run",
    "test:watch": "vitest",
    "playwright": "playwright",
    "playwright:install": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.5"
  }
}
